{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/_/backend/(.*)",
      "destination": "/_/backend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
